<html>
  <head>
    <meta charset='utf-8' />
    <title>Booking Confirmed - PopFlix</title>
  </head>
  <body
    style="margin: 0; padding: 0; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #f4f4f4;"
  >
    <table
      role='presentation'
      border='0'
      cellpadding='0'
      cellspacing='0'
      width='100%'
    >
      <tr>
        <td style='padding: 40px 0 30px 0; text-align: center;'>
          <img
            src='https://i.imgur.com/PXdKxvL.png'
            alt='PopFlix Logo'
            width='150'
            style='display: block; margin: 0 auto;'
          />
        </td>
      </tr>
      <tr>
        <td align='center'>
          <table
            role='presentation'
            border='0'
            cellpadding='0'
            cellspacing='0'
            width='600'
            style='background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1);'
          >
            <tr>
              <td style='padding: 40px 30px; text-align: center;'>
                <h1 style='color: #333333; margin: 0 0 20px 0;'>Booking
                  Confirmed!</h1>
                <p
                  style='color: #666666; font-size: 16px; line-height: 24px; margin-bottom: 30px;'
                >
                  Hi
                  {{name}}, your tickets for
                  <strong>{{movieTitle}}</strong>
                  are secured. Get your popcorn ready!
                </p>

                <table
                  width='100%'
                  border='0'
                  cellspacing='0'
                  cellpadding='10'
                  style='background-color: #fcfcfc; border: 1px solid #eeeeee; border-radius: 6px; text-align: left; margin-bottom: 30px;'
                >
                  <tr>
                    <td
                      style='color: #888; font-size: 14px; width: 120px;'
                    >Movie:</td>
                    <td
                      style='color: #333; font-weight: bold;'
                    >{{movieTitle}}</td>
                  </tr>
                  <tr>
                    <td style='color: #888; font-size: 14px;'>Time:</td>
                    <td style='color: #333; font-weight: bold;'>{{time}}</td>
                  </tr>
                  <tr>
                    <td style='color: #888; font-size: 14px;'>Location:</td>
                    <td
                      style='color: #333; font-weight: bold;'
                    >{{location}}</td>
                  </tr>
                  <tr>
                    <td style='color: #888; font-size: 14px;'>Seats:</td>
                    <td style='color: #333; font-weight: bold;'>{{seats}}</td>
                  </tr>
                  <tr>
                    <td style='color: #888; font-size: 14px;'>Total Price:</td>
                    <td
                      style='color: #ff5252; font-weight: bold;'
                    >RM{{totalPrice}}</td>
                  </tr>
                </table>

                <a
                  href='http://localhost:5173/profile/bookings'
                  style='background-color: #ff5252; color: #ffffff; padding: 15px 30px; text-decoration: none; border-radius: 50px; font-weight: bold; font-size: 16px; display: inline-block;'
                >
                  View My Bookings
                </a>
              </td>
            </tr>
            <tr>
              <td
                style='background-color: #f8f8f8; padding: 20px; text-align: center; color: #999999; font-size: 12px;'
              >
                <p style='margin: 0;'>PopFlix Cinema © 2026</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
      <tr>
        <td
          style='text-align: center; padding: 20px; color: #888888; font-size: 12px;'
        >
          <p>If you have any questions, contact our support team.</p>
        </td>
      </tr>
    </table>
  </body>
</html>